# /etc/openclaw-agent/config.env — OpenClaw VPS Agent configuration
#
# Copy this file to /etc/openclaw-control.env on your VPS:
#   sudo cp config.env.example /etc/openclaw-control.env
#   sudo chmod 600 /etc/openclaw-control.env
#   sudo chown root:root /etc/openclaw-control.env
#
# NEVER commit real secrets to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI (REQUIRED for chat feature) ───────────────────────────────────────

# API key for all OpenAI calls (Agents SDK + /chat endpoint).
OPENAI_API_KEY=sk-REPLACE_ME

# Chat model used by the /chat endpoint and Telegram bot.
# gpt-4o-mini is fast and affordable; swap for gpt-4o or gpt-4-turbo if needed.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: override the system prompt sent to the LLM.
# CHAT_SYSTEM_PROMPT=You are a helpful AI assistant.

# ── Authentication (REQUIRED in production) ──────────────────────────────────

# A long random string used to sign JWT session cookies.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET

# JWT signing algorithm (default: HS256). Only change if you have a specific need.
# JWT_ALGORITHM=HS256

# JWT lifetime in seconds (takes precedence over AUTH_TOKEN_EXPIRE_HOURS when set).
# Example: 604800 = 7 days
# JWT_EXPIRES_SECONDS=604800

# Admin account email — this account is created on first boot if absent.
AUTH_ADMIN_EMAIL=leeheggan@gmail.com

# TEMPORARY default password — CHANGE after the first login via the UI.
AUTH_ADMIN_DEFAULT_PASSWORD=changeme123

# Session token lifetime in hours (default: 168 = 7 days).
# AUTH_TOKEN_EXPIRE_HOURS=168

# Set to true when the app is served over HTTPS (e.g. behind Caddy).
# This adds the Secure flag to the session cookie so browsers only send it
# over encrypted connections.  Leave false (or unset) for local HTTP dev.
SECURE_COOKIES=true

# ── Telegram bot (optional) ──────────────────────────────────────────────────

# Token from @BotFather.  Leave blank to disable the bot.
# TELEGRAM_TOKEN and TELEGRAM_BOT_TOKEN are both accepted; TELEGRAM_TOKEN takes precedence.
TELEGRAM_TOKEN=REPLACE_ME
# TELEGRAM_BOT_TOKEN=REPLACE_ME  # legacy alias — use TELEGRAM_TOKEN above

# Base URL of the OpenClaw web app that the bot will call.
# Default is the local cockpit; override if your app is on a different host.
CHAT_API_URL=http://127.0.0.1:8001

# ── Chat database (optional) ─────────────────────────────────────────────────

# Path to the SQLite file used for conversation history and user accounts.
# The directory is created automatically if it does not exist.
# CHAT_DB_PATH=data/chat.db

# Maximum number of past messages included in each OpenAI request.
# CHAT_MAX_HISTORY=40

# ── GitHub integration (REQUIRED) ────────────────────────────────────────────

# Personal access token with repo scope (issues, labels, contents, pull_requests).
GITHUB_TOKEN=ghp_REPLACE_ME

# Repository to poll for agent:queue issues (owner/repo).
GITHUB_REPO=leeheggan-droid/openclaw-control

# ── VPS / SSH integration (REQUIRED for agent VPS queries and Vibe runs) ─────
#
# Execution lane (mutative operations — git pull, docker restart, vibe runs).
# Set to the SSH alias or user@host that has write permissions on the VPS.
# Leave blank to disable mutative SSH (the cockpit still works; ! commands fail).
OPENCLAW_SSH_HOST=user@your-vps-ip

# Read-only lane (probes, snapshots, autopilot evidence, terminal pills).
# Best practice: a separate restricted user + bin/vibe-readonly-wrapper.sh
# (see docs/ssh-execution-gateway.md).  When unset, read-only features are
# disabled gracefully — they NEVER fall back to OPENCLAW_SSH_HOST.
OPENCLAW_SSH_READONLY_HOST=readonly@your-vps-ip

# Private key file for the read-only SSH lane.
# When set, SSH is called with -i <path> so the correct key is used even if
# the default SSH agent / key differs (e.g. running under a service account).
# Leave blank to rely on the default SSH key (~/.ssh/id_ed25519 etc.).
# OPENCLAW_SSH_READONLY_KEY=/home/openclaw/.ssh/openclaw_readonly_ed25519

# Absolute path of the primary trading repo on the VPS.
# Injected into agent context and used by Vibe plan/execute as the default workdir.
OPENCLAW_REPO_DIR=/opt/openclaw-crypto

# Working directory used by Vibe plan/execute when the agent doesn't specify one.
# Defaults to OPENCLAW_REPO_DIR when unset.
# OPENCLAW_VIBE_WORKDIR=/opt/openclaw-crypto

# ── LLM provider selection (REQUIRED) ────────────────────────────────────────

# Which LLM provider to use: anthropic | gemini | groq
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) — required when LLM_PROVIDER=anthropic ────────────────

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Model to use; claude-3-haiku-20240307 is fast and cheap for planning tasks.
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Google Gemini — required when LLM_PROVIDER=gemini ────────────────────────

# GEMINI_API_KEY=AIza_REPLACE_ME
# GEMINI_MODEL=gemini-1.5-flash

# Optional second Gemini API key for fallback / load-balancing.
# GEMINI_API_KEY_2=AIza_REPLACE_ME

# ── Groq — required when LLM_PROVIDER=groq ───────────────────────────────────

# GROQ_API_KEY=gsk_REPLACE_ME
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Cheap Chat inference providers (optional) ────────────────────────────────
# Used by the /cheap-chat endpoint as fast/low-cost alternatives.

# MISTRAL_API_KEY=REPLACE_ME
# CEREBRAS_API_KEY=REPLACE_ME

# ── Web search (optional) ─────────────────────────────────────────────────────

# Brave Search API key — enables the web_search agent tool.
# BRAVE_API_KEY=REPLACE_ME

# ── Vibe executor (REQUIRED for VPS ops) ─────────────────────────────────────

# Base URL of the local Vibe HTTP gateway (preferred transport).
# Leave empty to fall back to the CLI at VIBE_CLI_PATH.
VIBE_API_BASE=http://127.0.0.1:7000

# API key for the Vibe gateway (if it requires one).
VIBE_API_KEY=REPLACE_ME

# Path to the Vibe CLI binary (fallback when VIBE_API_BASE is empty).
# VIBE_CLI_PATH=/usr/local/bin/vibe

# Comma-separated allowlist of permitted Vibe operations.
# Format: action_type:target  (use action_type:* to allow any target for that action)
# Only operations listed here will be executed; everything else is denied by default.
VIBE_ALLOWLIST=restart_service:openclaw-agent.service,tail_journal:openclaw-agent.service,read_file:/var/log/syslog

# ── Polling configuration (optional) ─────────────────────────────────────────

# How often (seconds) to poll GitHub for new agent:queue issues.
POLL_INTERVAL_SECONDS=30

# How long (seconds) to wait for a human /approve before timing out.
APPROVAL_TIMEOUT_SECONDS=3600

# ── Exchange API credentials (optional) ──────────────────────────────────────
# Used to fetch trade history from Kraken or Alpaca when the local trade log is empty.

# Kraken read-only API credentials.
# KRAKEN_API_KEY=REPLACE_ME
# KRAKEN_SECRET_KEY=REPLACE_ME  # also accepted as KRAKEN_API_SECRET (legacy)

# Alpaca read-only API credentials.
# ALPACA_API_KEY=REPLACE_ME
# ALPACA_SECRET_KEY=REPLACE_ME  # also accepted as ALPACA_API_SECRET / APCA_API_SECRET_KEY (legacy)

# ── Agent / environment identifiers (optional) ───────────────────────────────
# Useful when running multiple agents or deployments.

# AGENT_ID=REPLACE_ME
# ENV_ID=REPLACE_ME

# ── Web server (optional) ─────────────────────────────────────────────────────

# Port that uvicorn listens on (default: 8001).
# Used by the Dockerfile CMD; also read by openclaw_control.config.settings.port.
# PORT=8001

