# Example environment file for /etc/openclaw-control-api.env
#
# Required by the current VPS Control API implementation.
# Keep this value synchronized with:
# - Link/Vercel VPS_CONTROL_API_KEY
# - openclaw-control GitHub Actions secret VPS_CONTROL_API_KEY
VPS_CONTROL_API_KEY=replace-with-a-long-random-secret
#
# Optional future variables if LLM-backed operators are introduced later.
# They are NOT used by the current code:
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
