#!/usr/bin/env bash
# bin/vibe-openclaw — hardened SSH client for the OpenClaw → VPS vibe gateway
#
# Forwards a `vibe` invocation to the configured VPS over SSH using a
# dedicated, root-owned ED25519 key and a forced-command account.
#
# Usage:
#   vibe-openclaw --workdir <abs-path> --prompt <text>
#
# Required environment variable:
#   OPENCLAW_SSH_HOST   SSH target in "user@host" form, e.g. openclaw-vibe@203.0.113.10
#
# Optional environment variable:
#   OPENCLAW_VIBE_WORKDIR   Default workdir when --workdir is omitted.
#
# Exit codes mirror the remote vibe process exit code.
# SSH/connection errors produce exit code 1 with a diagnostic on stderr.

set -euo pipefail

# ── helpers ───────────────────────────────────────────────────────────────────

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") --workdir <abs-path> --prompt <text>

Environment:
  OPENCLAW_SSH_HOST       (required) SSH target, e.g. openclaw-vibe@host
  OPENCLAW_VIBE_WORKDIR   (optional) default workdir if --workdir is omitted
EOF
    exit 1
}

die() { echo "vibe-openclaw: error: $*" >&2; exit 1; }

# ── argument parsing ──────────────────────────────────────────────────────────

workdir=""
prompt=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --workdir)   shift; workdir="${1:-}"; shift ;;
        --prompt)    shift; prompt="${1:-}";  shift ;;
        --workdir=*) workdir="${1#*=}"; shift ;;
        --prompt=*)  prompt="${1#*=}";  shift ;;
        -h|--help)   usage ;;
        *) die "unknown argument: $1" ;;
    esac
done

# ── validation ────────────────────────────────────────────────────────────────

ssh_host="${OPENCLAW_SSH_HOST:-}"
[[ -n "$ssh_host" ]] || die "OPENCLAW_SSH_HOST is not set"

[[ -n "$workdir" ]] || workdir="${OPENCLAW_VIBE_WORKDIR:-}"
[[ -n "$workdir" ]] || die "--workdir is required (or set OPENCLAW_VIBE_WORKDIR)"

[[ -n "$prompt"  ]] || die "--prompt is required"

# ── build remote command ──────────────────────────────────────────────────────
# printf %q produces POSIX shell-quoted tokens safe for eval on the remote side.

quoted_workdir="$(printf '%q' "$workdir")"
quoted_prompt="$(printf '%q' "$prompt")"
remote_cmd="vibe --workdir ${quoted_workdir} --prompt ${quoted_prompt}"

# ── execute ───────────────────────────────────────────────────────────────────

echo "vibe-openclaw: connecting to ${ssh_host}" >&2
echo "vibe-openclaw: workdir=${workdir}" >&2
echo "vibe-openclaw: prompt=${prompt}" >&2

exec ssh \
    -i /root/.ssh/openclaw_vibe_ed25519 \
    -o IdentitiesOnly=yes \
    -o PreferredAuthentications=publickey \
    -o PasswordAuthentication=no \
    -o KbdInteractiveAuthentication=no \
    -o BatchMode=yes \
    -o StrictHostKeyChecking=yes \
    -o UserKnownHostsFile=/root/.ssh/known_hosts \
    -o ConnectTimeout=10 \
    "$ssh_host" \
    "$remote_cmd"
